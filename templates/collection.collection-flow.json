          "name": "t:names.heading",
          "settings": {
            "text": "<p>One blend, three textures</p>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "left",
            "type_preset": "h3",
            "font": "var(--font-body--family)",
