    "section_pmKGK3": {
      "type": "section",
      "blocks": {
        "text_UG8PtV": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p>A lot of people are a mix, oilier through the T-zone across the forehead, nose and chin, and drier on the cheeks. That combination usually sits close to balanced. If one tendency is clearly stronger than the other, lean that way, and remember you can always treat a particular area differently, which is what the note at the end covers.</p>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "left",
            "type_preset": "rte",
            "font": "var(--font-body--family)",
            "font_size": "",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
            "wrap": "pretty",
