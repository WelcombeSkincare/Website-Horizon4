    "section_6KmeeW": {
      "type": "section",
      "blocks": {
        "text_FtFYad": {
          "type": "text",
          "name": "t:names.text",
          "disabled": true,
          "settings": {
            "text": "<p>As with any new product on reactive skin, it's worth patch testing first.<br/><br/></p>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "left",
