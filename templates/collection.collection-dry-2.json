        "text_QawbWf": {
          "type": "text",
          "name": "t:names.heading",
          "settings": {
            "text": "<p>Looking after Dry skin</p>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "left",
            "type_preset": "h3",
            "font": "var(--font-body--family)",
            "font_size": "1rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
